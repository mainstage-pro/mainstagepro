generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                String    @default("USER") // ADMIN | USER | READONLY
  area                String?   @default("GENERAL") // DIRECCION | ADMINISTRACION | MARKETING | VENTAS | PRODUCCION | GENERAL
  active              Boolean   @default(true)
  fechaInicioVendedor DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tratos          Trato[]
  tratosOrigen    Trato[]            @relation("TratoVendedorOrigen")
  proyectos       Proyecto[]
  cotizaciones    Cotizacion[]
  bitacoras       ProyectoBitacora[]
  comisionesPagos ComisionPago[]
  moduloAccesos   ModuloAcceso[]
  tareasAsignadas       Tarea[]           @relation("TareasAsignadas")
  tareasCreadoPor       Tarea[]           @relation("TareasCreadoPor")
  iniciativasCreadas    IniciativaExterna[] @relation("IniciativasCreadas")
  carpetasCreadas       TareaCarpeta[]    @relation("CarpetasCreadas")
  proyectosTareaCreados TareaProyecto[]   @relation("ProyectosTareaCreados")
  comentariosTarea      TareaComentario[] @relation("ComentariosTarea")
  archivosTarea         TareaArchivo[]    @relation("ArchivosTarea")
  actividades           ActividadUsuario[] @relation("actividades")
  versiones             VersionHistorial[] @relation("versiones")
  clientesVendedor      Cliente[]          @relation("ClientesVendedor")
  notificaciones        Notificacion[]

  @@map("users")
}

model ActividadUsuario {
  id          String   @id @default(cuid())
  userId      String
  usuario     User     @relation("actividades", fields: [userId], references: [id])
  accion      String   // CREAR | EDITAR | ELIMINAR | APROBAR | ENVIAR | VER
  entidad     String   // cotizacion | proyecto | cliente | trato | etc.
  entidadId   String?
  descripcion String
  datos       String?  // JSON metadata
  createdAt   DateTime @default(now())
  @@map("actividad_usuario")
  @@index([userId])
  @@index([createdAt])
}

model VersionHistorial {
  id         String   @id @default(cuid())
  entidad    String   // "proyecto" | "cotizacion"
  entidadId  String
  userId     String
  usuario    User     @relation("versiones", fields: [userId], references: [id])
  snapshot   String   // JSON snapshot
  nota       String?
  createdAt  DateTime @default(now())
  @@map("version_historial")
  @@index([entidad, entidadId])
}

// ─── EMPRESA ─────────────────────────────────────────────────────────────────

model Empresa {
  id             String   @id @default(cuid())
  nombre         String
  giro           String?
  telefono       String?
  correo         String?
  sitioWeb       String?
  notas          String?
  rfc            String?
  datosFiscales  String?
  cuentaBancaria String?  // número de cuenta
  clabe          String?
  banco          String?
  noTarjeta      String?
  tipo           String   @default("AMBOS")  // CLIENTE | PROVEEDOR | AMBOS
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contactosCliente   Cliente[]   @relation("ClienteEmpresa")
  contactosProveedor Proveedor[] @relation("ProveedorEmpresa")
  cuentasCobrar      CuentaCobrar[]
  cuentasPagar       CuentaPagar[]

  @@map("empresas")
}

// ─── CLIENTE ─────────────────────────────────────────────────────────────────

model Cliente {
  id            String   @id @default(cuid())
  nombre        String
  empresa       String?
  empresaId     String?
  compania      Empresa? @relation("ClienteEmpresa", fields: [empresaId], references: [id])
  tipoCliente   String   @default("POR_DESCUBRIR") // B2B | B2C | POR_DESCUBRIR
  clasificacion String   @default("NUEVO")          // NUEVO | BASIC | REGULAR | PRIORITY
  servicioUsual String?  // RENTA | PRODUCCION_TECNICA | DIRECCION_TECNICA | MULTISERVICIO
  telefono      String?
  correo        String?
  notas         String?
  vendedorId    String?
  vendedor      User?    @relation("ClientesVendedor", fields: [vendedorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tratos          Trato[]
  cotizaciones    Cotizacion[]
  proyectos       Proyecto[]
  cuentasCobrar   CuentaCobrar[]
  movimientos     MovimientoFinanciero[]
  preciosEquipos  PrecioClienteEquipo[]

  @@map("clientes")
}

model PrecioClienteEquipo {
  id        String  @id @default(cuid())
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  equipoId  String
  equipo    Equipo  @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  precio         Float
  precioOriginal Float?   // precio de lista al momento de registrar el especial
  nota           String?
  updatedAt      DateTime @updatedAt

  @@unique([clienteId, equipoId])
  @@map("precios_cliente_equipo")
}

// ─── TRATO ───────────────────────────────────────────────────────────────────

model Trato {
  id                  String   @id @default(cuid())
  clienteId           String
  cliente             Cliente  @relation(fields: [clienteId], references: [id])
  responsableId       String?
  responsable         User?    @relation(fields: [responsableId], references: [id])
  tipoEvento          String   @default("OTRO")         // MUSICAL | SOCIAL | EMPRESARIAL | OTRO
  tipoLead            String   @default("INBOUND")      // INBOUND | OUTBOUND
  origenLead          String   @default("ORGANICO")     // META_ADS | GOOGLE_ADS | ORGANICO | RECOMPRA | REFERIDO | PROSPECCION | OTRO
  estatusContacto     String   @default("PENDIENTE")    // PENDIENTE | CONTACTADO
  etapa               String   @default("DESCUBRIMIENTO") // DESCUBRIMIENTO | OPORTUNIDAD | VENTA_CERRADA | VENTA_PERDIDA
  clasificacion       String   @default("PROSPECTO")    // PROSPECTO | BASIC | REGULAR | PRIORITY
  tipoServicio        String?  // RENTA | PRODUCCION_TECNICA | DIRECCION_TECNICA

  // ── Descubrimiento ────────────────────────────────────────────────────────
  canalAtencion          String?   // WHATSAPP | FORMULARIO | LLAMADA | REUNION | SCOUTING | INFORMACION
  nombreEvento           String?
  duracionEvento         String?   // ej: "6 horas", "2 días"
  asistentesEstimados    Int?
  serviciosInteres       String?   // JSON: ["AUDIO_PA","ILUMINACION","VIDEO_LED",...]
  ideasReferencias       String?   // links o descripción de referencias
  etapaContratacion      String?   // obsoleto — reemplazado por rutaEntrada
  rutaEntrada            String?   // DESCUBRIR | RIDER_DIRECTO
  continuarPor           String?   // WHATSAPP | LLAMADA | REUNION | COTIZACION
  descubrimientoCompleto Boolean   @default(false)
  // ──────────────────────────────────────────────────────────────────────────

  lugarEstimado       String?
  fechaEventoEstimada DateTime?
  presupuestoEstimado Float?
  notas               String?
  proximaAccion       String?
  fechaProximaAccion  DateTime?
  formToken           String?  @unique
  formEstado          String   @default("NO_ENVIADO") // NO_ENVIADO | ENVIADO | COMPLETADO
  formRespuestas      String?  // JSON con respuestas del prospecto

  // ── Horarios del evento (capturados durante ventas) ─────────────────────
  horaInicioEvento   String?  // ej: "18:00"
  horaFinEvento      String?  // ej: "23:00"
  duracionMontajeHrs Float?   // estimado en horas
  // ── Logística del venue ──────────────────────────────────────────────────
  ventanaMontajeInicio  String?  // ej: "08:00" — hora más temprana de acceso al venue
  ventanaMontajeFin     String?  // ej: "14:00" — hora límite para terminar montaje
  horaTerminoMontaje    String?  // hora en que debe concluir el desmontaje / salida del venue
  // ── Contacto del venue ───────────────────────────────────────────────────
  contactoVenueNombre   String?  // nombre del coordinador / encargado del venue
  contactoVenueTelefono String?  // teléfono del coordinador del venue
  // ── Origen de campos (para saber quién capturó qué) ──────────────────────
  camposCliente         String?  // JSON array de IDs de campos llenados por el cliente
  // ─────────────────────────────────────────────────────────────────────────

  scoutingData        String?  // JSON: venue scouting form data
  // ── Mainstage Trade ──────────────────────────────────────────────────────────
  tradeCalificado     Boolean  @default(false)
  tradeNivel          Int?     // 1 = Base | 2 = Estratégico | 3 = Premium
  familyAndFriends    Boolean  @default(false)
  realizarRender      Boolean  @default(false)
  // ─────────────────────────────────────────────────────────────────────────────
  tipoProspecto       String   @default("ACTIVO")  // ACTIVO | NURTURING
  nurturingData       String?  // JSON: { etapa, temperatura, nextFollowup, nextMotivo, log[] }
  motivoPerdida       String?
  etapaCambiadaEn     DateTime?
  origenVenta         String   @default("CLIENTE_PROPIO") // CLIENTE_PROPIO | PUBLICIDAD | ASIGNADO
  vendedorOrigenId    String?
  vendedorOrigen      User?    @relation("TratoVendedorOrigen", fields: [vendedorOrigenId], references: [id])
  fechaCierre         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cotizaciones           Cotizacion[]
  proyecto               Proyecto?
  archivos               TratoArchivo[]
  levantamientoContenido LevantamientoContenido?

  @@map("tratos")
}

model TratoArchivo {
  id        String   @id @default(cuid())
  tratoId   String
  trato     Trato    @relation(fields: [tratoId], references: [id], onDelete: Cascade)
  nombre    String
  url       String
  tipo      String   @default("OTRO") // IMAGEN | DOCUMENTO | REFERENCIA | OTRO
  subidoPor String?
  createdAt DateTime @default(now())

  @@map("trato_archivos")
}

// ─── COTIZACIÓN ──────────────────────────────────────────────────────────────

model Cotizacion {
  id               String   @id @default(cuid())
  numeroCotizacion String   @unique
  version          Int      @default(1)
  opcionLetra      String   @default("A") @map("opcion_letra")
  grupoId          String?  @map("grupo_id")
  tratoId          String
  trato            Trato    @relation(fields: [tratoId], references: [id])
  clienteId        String
  cliente          Cliente  @relation(fields: [clienteId], references: [id])
  creadaPorId      String?
  creadaPor        User?    @relation(fields: [creadaPorId], references: [id])
  estado           String   @default("BORRADOR") // BORRADOR | ENVIADA | EN_REVISION | AJUSTE_SOLICITADO | REENVIADA | APROBADA | RECHAZADA | VENCIDA
  nombreEvento     String?
  tipoEvento       String?
  tipoServicio     String?
  fechaEvento      DateTime?
  lugarEvento      String?
  horasOperacion   Float?
  tipoJornada      String?  // CORTA | MEDIA | LARGA
  notasSecciones   String?  // JSON: { "Audio": "nota", "Iluminación": "nota", ... }

  diasEquipo     Int @default(1)
  diasOperacion  Int @default(1)
  diasTransporte Int @default(1)
  diasHospedaje  Int @default(1)
  diasComidas    Int @default(1)

  subtotalEquiposBruto   Float @default(0)
  descuentoVolumenPct    Float @default(0)
  descuentoB2bPct        Float @default(0)
  descuentoMultidiaPct   Float @default(0)
  descuentoPatrocinioPct Float @default(0)
  descuentoPatrocinioNota String?
  descuentoEspecialPct        Float @default(0)
  descuentoEspecialNota       String?
  descuentoFamilyFriendsPct   Float @default(0)
  descuentoTotalPct           Float @default(0)
  montoDescuento         Float @default(0)
  subtotalEquiposNeto    Float @default(0)
  subtotalPaquetes       Float @default(0)
  subtotalTerceros       Float @default(0)
  subtotalOperacion      Float @default(0)
  subtotalTransporte     Float @default(0)
  subtotalComidas        Float @default(0)
  subtotalHospedaje      Float @default(0)
  total                  Float @default(0)
  aplicaIva              Boolean @default(false)
  incluirChofer          Boolean @default(false)  // Toggle: agregar servicio de chofer ($500)
  montoIva               Float @default(0)
  granTotal              Float @default(0)

  tipoBeneficio  String? // DESCUENTO_DIRECTO | SALDO_A_FAVOR
  montoBeneficio Float   @default(0)

  costosTotalesEstimados Float @default(0)
  utilidadEstimada       Float @default(0)
  porcentajeUtilidad     Float @default(0)

  mainstageTradeData  String?  // JSON: { activo, pct, entregables[], checklist, nivelSeleccionado, nivelAplicado, bonoVariable, clienteSeleccionoEn }
  tradeToken          String?  @unique @map("trade_token")
  planPagos           String?  // JSON: esquema de pagos (porcentajes y fechas para CxC)
  observaciones       String?
  terminosComerciales String?
  vigenciaDias        Int      @default(30)
  fechaEnvio          DateTime?
  fechaVencimiento    DateTime?
  aprobacionToken     String?  @unique @map("aprobacion_token")
  aprobacionFecha     DateTime? @map("aprobacion_fecha")
  aprobacionNombre    String?  @map("aprobacion_nombre")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  lineas        CotizacionLinea[]
  proyecto      Proyecto?
  cuentasCobrar CuentaCobrar[]

  @@map("cotizaciones")
}

model CotizacionLinea {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tipo         String     // EQUIPO_PROPIO | EQUIPO_EXTERNO | PAQUETE | OPERACION_TECNICA | TRANSPORTE | HOSPEDAJE | COMIDA | DJ | DESCUENTO_BENEFICIO | OTRO
  orden        Int        @default(0)

  equipoId     String?
  equipo       Equipo?     @relation(fields: [equipoId], references: [id])
  rolTecnicoId String?
  rolTecnico   RolTecnico? @relation(fields: [rolTecnicoId], references: [id])

  descripcion    String
  marca          String?
  modelo         String?
  nivel          String?  // AAA | AA | A
  jornada        String?  // CORTA | MEDIA | LARGA
  esExterno      Boolean  @default(false)
  proveedorId    String?
  proveedor      Proveedor? @relation(fields: [proveedorId], references: [id])
  costoExterno   Float?
  cantidad       Float    @default(1)
  dias           Int      @default(1)
  precioUnitario Float    @default(0)
  costoUnitario  Float    @default(0)
  subtotal       Float    @default(0)
  esIncluido     Boolean  @default(false)
  notas          String?

  @@map("cotizacion_lineas")
}

// ─── PROYECTO ────────────────────────────────────────────────────────────────

model Proyecto {
  id             String   @id @default(cuid())
  numeroProyecto String   @unique
  tratoId        String   @unique
  trato          Trato    @relation(fields: [tratoId], references: [id])
  cotizacionId   String   @unique
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id])
  clienteId      String
  cliente        Cliente  @relation(fields: [clienteId], references: [id])
  encargadoId    String?
  encargado      User?    @relation(fields: [encargadoId], references: [id])

  nombre                 String
  estado                 String   @default("PLANEACION") // PLANEACION | CONFIRMADO | EN_CURSO | COMPLETADO | CANCELADO
  tipoEvento             String
  tipoServicio           String?
  fechaEvento            DateTime
  horaInicioEvento       String?
  horaFinEvento          String?
  fechaMontaje           DateTime?
  horaInicioMontaje      String?
  duracionMontajeHrs     Float?
  lugarEvento            String?
  encargadoLugar         String?
  encargadoLugarContacto String?
  descripcionGeneral     String?
  detallesEspecificos    String?
  encargadoCliente       String?  // Nombre del encargado de parte del cliente
  transportes            String?  // Descripción de transportes del evento
  proveedorCatering      String?  // Proveedor de catering / alimentación producción
  contactosDireccion     String?  // Contactos de dirección y coordinación
  cronograma             String?
  contactosEmergencia    String?
  comentariosFinales     String?
  scoreFotoVideo         Int?
  recomendacionFotoVideo String?
  // Logística de renta (JSON con modalidad, fechas, dirección de entrega/devolución)
  logisticaRenta         String?
  // Reporte de catering (JSON: contactoNombre, contactoTelefono, personasCrew, comidas[], notas)
  reporteCatering        String?
  // Marketing content (JSON: { activo: boolean, telefono: string, nombre: string })
  marketingData          String?
  // Documentos técnicos por tipo de evento (JSON estructurado)
  docsTecnicos           String?
  // Chofer asignado al proyecto
  choferNombre           String?   // Nombre del chofer (del personal del proyecto o externo)
  choferExterno          Boolean   @default(false)  // true = chofer externo (genera CxP)
  choferCosto            Float?    // Costo del chofer externo
  // Recolección de equipo rentado (solo proyectos RENTA)
  recoleccionStatus      String    @default("NO_APLICA")  // NO_APLICA | PENDIENTE | EN_CAMINO | COMPLETADA
  recoleccionNotas       String?   // Observaciones al recolectar (daños, faltantes, etc.)
  recoleccionFechaReal   DateTime? // Fecha/hora real en que se recolectó el equipo
  protocoloSalida        String?   // JSON: protocolo de entrega al cliente (responsable, condicion, items[], timestamp)
  protocoloEntrada       String?   // JSON: protocolo de recepción en bodega (responsable, condicion, danios, items[], timestamp)
  portalToken            String?   @unique // Token público para portal de cliente
  notasPortal            String?   // Mensaje visible al cliente en su portal
  responsables           String?   // JSON: { produccion, logistica, finanzas, marketing } → { userId, nombre }
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  personal          ProyectoPersonal[]
  equipos           ProyectoEquipo[]
  checklist         ProyectoChecklist[]
  archivos          ProyectoArchivo[]
  bitacora          ProyectoBitacora[]
  cuentasCobrar     CuentaCobrar[]
  cuentasPagar      CuentaPagar[]
  movimientos       MovimientoFinanciero[]
  evaluacionInterna EvaluacionInterna?
  evaluacionCliente EvaluacionCliente?
  gastosOperativos  GastoOperativo[]
  ordenesCompra     OrdenCompra[]
  cierreFinanciero  CierreFinanciero?

  @@map("proyectos")
}

model ProyectoPersonal {
  id              String   @id @default(cuid())
  proyectoId      String
  proyecto        Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tecnicoId       String?
  tecnico         Tecnico? @relation(fields: [tecnicoId], references: [id])
  rolTecnicoId    String?
  rolTecnico      RolTecnico? @relation(fields: [rolTecnicoId], references: [id])
  participacion   String?  // OPERACION | MONTAJE | DESMONTAJE | TRANSPORTE | OTRO
  nivel           String?  // AAA | AA | A
  jornada         String?  // CORTA | MEDIA | LARGA
  responsabilidad String?
  confirmado      Boolean  @default(false)
  confirmRespuesta String? // CONFIRMADO | RECHAZADO
  confirmToken    String?  @unique // Token para link de confirmación por WhatsApp
  tarifaAcordada  Float?
  estadoPago      String   @default("PENDIENTE") // PENDIENTE | PAGADO
  notas           String?

  @@map("proyecto_personal")
}

model ProyectoEquipo {
  id               String    @id @default(cuid())
  proyectoId       String
  proyecto         Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  equipoId         String
  equipo           Equipo    @relation(fields: [equipoId], references: [id])
  tipo             String    @default("PROPIO") // PROPIO | EXTERNO
  cantidad         Int       @default(1)
  dias             Int       @default(1)
  costoExterno     Float?
  proveedorId      String?
  proveedor        Proveedor? @relation(fields: [proveedorId], references: [id])
  confirmado       Boolean   @default(false)
  confirmDisponible Boolean? // Respuesta del proveedor sobre disponibilidad
  confirmToken     String?   @unique // Token para link de confirmación al proveedor
  riderAccesorios  RiderAccesorio[]

  @@map("proyecto_equipos")
}

// Accesorios de rider para un equipo en un proyecto específico
model RiderAccesorio {
  id               String         @id @default(cuid())
  proyectoEquipoId String
  proyectoEquipo   ProyectoEquipo @relation(fields: [proyectoEquipoId], references: [id], onDelete: Cascade)
  nombre           String
  categoria        String?        // cable | herramienta | consumible | soporte | otro
  completado       Boolean        @default(false)
  esSugerencia     Boolean        @default(false)
  orden            Int            @default(0)
  createdAt        DateTime       @default(now())

  @@map("rider_accesorios")
}

model ProyectoChecklist {
  id              String    @id @default(cuid())
  proyectoId      String
  proyecto        Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tipo            String    @default("OPERACION") // OPERACION | RIDER
  item            String
  completado      Boolean   @default(false)
  completadoPor   String?
  fechaCompletado DateTime?
  orden           Int       @default(0)
  notas           String?

  @@map("proyecto_checklist")
}

model ProyectoArchivo {
  id         String   @id @default(cuid())
  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tipo       String   // RENDER | PLOT_PATCH | INPUT_LIST | RIDER | ITINERARIO | DOCUMENTO | OTRO
  nombre     String
  url        String
  subidoPor  String?
  createdAt  DateTime @default(now())

  @@map("proyecto_archivos")
}

model ProyectoBitacora {
  id         String   @id @default(cuid())
  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuarioId  String?
  usuario    User?    @relation(fields: [usuarioId], references: [id])
  tipo       String   @default("NOTA") // NOTA | CAMBIO | ALERTA | ACCION
  contenido  String
  createdAt  DateTime @default(now())

  @@map("proyecto_bitacora")
}

// ─── CATÁLOGOS ───────────────────────────────────────────────────────────────

model Equipo {
  id                   String          @id @default(cuid())
  categoriaId          String
  categoria            CategoriaEquipo @relation(fields: [categoriaId], references: [id])
  subcategoria         String?
  marca                String?
  modelo               String?
  descripcion          String
  cantidadTotal        Int             @default(1)
  tipo                 String          @default("PROPIO") // PROPIO | EXTERNO
  proveedorDefaultId   String?
  proveedorDefault     Proveedor?      @relation("ProveedorDefault", fields: [proveedorDefaultId], references: [id])
  precioRenta          Float           @default(0)  // Precio que cobramos al cliente
  costoProveedor       Float?                        // Costo que nos cobra el proveedor (solo equipos externos)
  costoInternoEstimado Float?                        // Costo interno estimado (mantenimiento, para equipos propios)
  estado               String          @default("ACTIVO") // ACTIVO | EN_MANTENIMIENTO | DADO_DE_BAJA
  amperajeRequerido    Float?          // Consumo eléctrico en amperes
  voltajeRequerido     Int?            // Voltaje requerido (110 | 220 | etc.)
  notas                String?
  imagenUrl            String?         // URL principal del equipo (ruta /inventario/equipos/... o base64)
  imagenesUrls         String?         // JSON array de URLs adicionales
  activo               Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  cotizacionLineas     CotizacionLinea[]
  proyectoEquipos      ProyectoEquipo[]
  mantenimientos       MantenimientoEquipo[]
  plantillaItems       PlantillaEquipoItem[]
  plantillaCotizacionLineas PlantillaCotizacionLinea[]
  preciosClientes      PrecioClienteEquipo[]
  checklistBodegaItems ChecklistBodegaItem[]
  unidades             EquipoUnidad[]
  accesorios           EquipoAccesorio[]

  @@map("equipos")
}

// Biblioteca permanente de accesorios por equipo (persiste entre proyectos)
model EquipoAccesorio {
  id        String   @id @default(cuid())
  equipoId  String
  equipo    Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  nombre    String
  categoria String?  // cable | herramienta | consumible | soporte | otro
  createdAt DateTime @default(now())

  @@map("equipo_accesorios")
}

model CategoriaEquipo {
  id      String   @id @default(cuid())
  nombre  String   @unique
  orden   Int      @default(0)
  equipos Equipo[]

  @@map("categoria_equipos")
}

model RolTecnico {
  id          String  @id @default(cuid())
  nombre      String
  tipoPago    String  @default("POR_JORNADA") // POR_JORNADA | POR_PROYECTO | POR_HORA | TARIFA_PLANA

  tarifaAAACorta Float?
  tarifaAAAMedia Float?
  tarifaAAALarga Float?
  tarifaAACorta  Float?
  tarifaAAMedia  Float?
  tarifaAALarga  Float?
  tarifaACorta   Float?
  tarifaAMedia   Float?
  tarifaALarga   Float?

  tarifaPlanaAAA Float?
  tarifaPlanaAA  Float?
  tarifaPlanaA   Float?

  tarifaHoraAAA Float?
  tarifaHoraAA  Float?
  tarifaHoraA   Float?

  descripcion String?
  activo      Boolean @default(true)
  orden       Int     @default(0)

  cotizacionLineas CotizacionLinea[]
  proyectoPersonal ProyectoPersonal[]
  tecnicos         Tecnico[]

  @@map("roles_tecnicos")
}

model Tecnico {
  id                 String     @id @default(cuid())
  nombre             String
  celular            String?
  rolId              String?
  rol                RolTecnico? @relation(fields: [rolId], references: [id])
  nivel              String     @default("A") // AAA | AA | A
  zonaHabitual       String?
  evaluacionPromedio Float?
  cuentaBancaria     String?
  datosFiscales      String?
  activo             Boolean    @default(true)
  comentarios        String?
  habilidades        String?    // JSON array of skill tags
  createdAt          DateTime   @default(now())

  proyectoPersonal ProyectoPersonal[]
  cuentasPagar     CuentaPagar[]

  @@map("tecnicos")
}

model Proveedor {
  id             String   @id @default(cuid())
  nombre         String
  empresa        String?
  empresaId      String?
  compania       Empresa? @relation("ProveedorEmpresa", fields: [empresaId], references: [id])
  giro           String?
  telefono       String?
  correo         String?
  notas          String?
  rfc            String?
  cuentaBancaria String?  // número de cuenta
  clabe          String?
  banco          String?
  noTarjeta      String?
  datosFiscales  String?
  activo         Boolean  @default(true)
  portalToken    String?  @unique @map("portal_token")
  createdAt      DateTime @default(now())

  equiposDefault   Equipo[]           @relation("ProveedorDefault")
  cotizacionLineas CotizacionLinea[]
  proyectoEquipos  ProyectoEquipo[]
  cuentasPagar     CuentaPagar[]
  movimientos      MovimientoFinanciero[]
  ordenesCompra    OrdenCompra[]
  equiposPortal    EquipoProveedor[]

  @@map("proveedores")
}

model GiroProveedor {
  id        String   @id @default(cuid())
  nombre    String   @unique
  createdAt DateTime @default(now())

  @@map("giros_proveedor")
}

model EquipoProveedor {
  id               String    @id @default(cuid())
  proveedorId      String    @map("proveedor_id")
  proveedor        Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  // Identificación
  categoria        String    @default("OTRO")  // AUDIO | VIDEO | ILUMINACION | BACKLINE | ESCENOGRAFIA | LOGISTICA | OTRO
  descripcion      String
  marca            String?
  modelo           String?
  serialNum        String?   @map("serial_num")
  anioFabricacion  Int?      @map("anio_fabricacion")

  // Inventario y condición
  cantidad         Int       @default(1)
  condicion        String    @default("BUENO")  // NUEVO | BUENO | REGULAR | NECESITA_REVISION
  disponibilidad   String    @default("DISPONIBLE") // DISPONIBLE | EN_USO | EN_MANTENIMIENTO | NO_DISPONIBLE

  // Especificaciones técnicas
  potenciaW        Float?    @map("potencia_w")
  voltaje          String?   // "110" | "220" | "110/220"
  amperaje         Float?
  pesoKg           Float?    @map("peso_kg")
  dimensiones      String?   // "L x A x H cm"
  incluyeCase      Boolean   @default(false) @map("incluye_case")
  tiempoSetupMin   Int?      @map("tiempo_setup_min")

  // Precios (legado)
  precioDia        Float?    @map("precio_dia")
  precioEventoFull Float?    @map("precio_evento_full")
  precioMinimoEvent Float?   @map("precio_minimo_event")
  // Precios nuevos
  precioPublico    Float?    @map("precio_publico")    // Precio sugerido al público por el proveedor
  precioMainstage  Float?    @map("precio_mainstage")  // Precio que cobra a Mainstage

  // Notas y documentación
  notas            String?
  fotosUrls        String?   @map("fotos_urls")   // JSON array de URLs
  fichaTecnicaUrl  String?   @map("ficha_tecnica_url")

  // Control interno
  aprobado         Boolean   @default(false)
  importadoEquipoId String?  @map("importado_equipo_id")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  @@map("equipos_proveedor")
}

// ─── ÓRDENES DE COMPRA ───────────────────────────────────────────────────────

model OrdenCompra {
  id            String    @id @default(cuid())
  numero        String    @unique
  proveedorId   String    @map("proveedor_id")
  proveedor     Proveedor @relation(fields: [proveedorId], references: [id])
  proyectoId    String?   @map("proyecto_id")
  proyecto      Proyecto? @relation(fields: [proyectoId], references: [id])
  descripcion   String
  estado        String    @default("PENDIENTE") @map("estado") // PENDIENTE | CONFIRMADA | RECIBIDA | CANCELADA
  fechaRequerida DateTime? @map("fecha_requerida")
  fechaEntrega   DateTime? @map("fecha_entrega")
  monto         Float     @default(0)
  montoIva      Float     @default(0) @map("monto_iva")
  total         Float     @default(0)
  notas         String?
  lineas        String?   // JSON: [{descripcion, cantidad, precioUnitario, subtotal}]
  creadoPorId   String?   @map("creado_por_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  @@map("ordenes_compra")
}

// ─── FINANZAS ────────────────────────────────────────────────────────────────

model CuentaBancaria {
  id           String  @id @default(cuid())
  nombre       String
  banco        String?
  numeroCuenta String?
  clabe        String?
  titular      String?
  rfc          String?
  activa       Boolean @default(true)

  movimientosEntrada MovimientoFinanciero[] @relation("CuentaDestino")
  movimientosSalida  MovimientoFinanciero[] @relation("CuentaOrigen")
  cuentasCobrar      CuentaCobrar[]
  cuentasPagar       CuentaPagar[]
  pagosNomina        PagoNomina[]

  @@map("cuentas_bancarias")
}

model CategoriaFinanciera {
  id     String @id @default(cuid())
  nombre String
  tipo   String // INGRESO | GASTO | TRANSFERENCIA | INVERSION | RETIRO
  orden  Int    @default(0)

  movimientos MovimientoFinanciero[]

  @@map("categorias_financieras")
}

model MovimientoFinanciero {
  id                  String   @id @default(cuid())
  fecha               DateTime
  cuentaOrigenId      String?
  cuentaOrigen        CuentaBancaria? @relation("CuentaOrigen", fields: [cuentaOrigenId], references: [id])
  cuentaDestinoId     String?
  cuentaDestino       CuentaBancaria? @relation("CuentaDestino", fields: [cuentaDestinoId], references: [id])
  tipo                String   // INGRESO | GASTO | TRANSFERENCIA | INVERSION | RETIRO
  clienteId           String?
  cliente             Cliente? @relation(fields: [clienteId], references: [id])
  proveedorId         String?
  proveedor           Proveedor? @relation(fields: [proveedorId], references: [id])
  proyectoId          String?
  proyecto            Proyecto? @relation(fields: [proyectoId], references: [id])
  categoriaId         String?
  categoria           CategoriaFinanciera? @relation(fields: [categoriaId], references: [id])
  concepto            String
  monto               Float
  metodoPago          String   @default("TRANSFERENCIA") // TRANSFERENCIA | EFECTIVO | TARJETA | CHEQUE
  referencia          String?
  estatusConciliacion String   @default("PENDIENTE") // PENDIENTE | CONCILIADO
  comprobanteUrl      String?
  notas               String?
  creadoPor           String?
  createdAt           DateTime @default(now())

  cuentaCobrar CuentaCobrar?
  cuentaPagar  CuentaPagar?
  pagoNomina   PagoNomina?

  @@map("movimientos_financieros")
}

model CuentaCobrar {
  id              String   @id @default(cuid())
  clienteId       String?
  cliente         Cliente? @relation(fields: [clienteId], references: [id])
  empresaId       String?
  empresa         Empresa? @relation(fields: [empresaId], references: [id])
  proyectoId      String?
  proyecto        Proyecto? @relation(fields: [proyectoId], references: [id])
  cotizacionId    String?
  cotizacion      Cotizacion? @relation(fields: [cotizacionId], references: [id])
  concepto        String
  tipoPago        String   @default("ANTICIPO") // ANTICIPO | LIQUIDACION | OTRO
  monto           Float
  fechaCompromiso DateTime
  fechaCobroReal  DateTime?
  estado          String   @default("PENDIENTE") // PENDIENTE | PARCIAL | LIQUIDADO | VENCIDO
  montoCobrado    Float    @default(0)
  cuentaDestinoId String?
  cuentaDestino   CuentaBancaria? @relation(fields: [cuentaDestinoId], references: [id])
  movimientoId    String?  @unique
  movimiento      MovimientoFinanciero? @relation(fields: [movimientoId], references: [id])
  notas           String?
  montoOriginal   Float?   // monto al momento de la creación, antes de ajustes
  ajustesLog      String?  // JSON: [{fecha, de, a, motivo, usuario}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cuentas_cobrar")
}

model CuentaPagar {
  id              String   @id @default(cuid())
  tipoAcreedor    String   // PROVEEDOR | TECNICO | PERSONAL_INTERNO | OTRO | EMPRESA | SOCIO
  tecnicoId       String?
  tecnico         Tecnico? @relation(fields: [tecnicoId], references: [id])
  proveedorId     String?
  proveedor       Proveedor? @relation(fields: [proveedorId], references: [id])
  empresaId       String?
  empresa         Empresa? @relation(fields: [empresaId], references: [id])
  socioId         String?
  socio           Socio? @relation(fields: [socioId], references: [id])
  proyectoId      String?
  proyecto        Proyecto? @relation(fields: [proyectoId], references: [id])
  concepto        String
  monto           Float
  fechaCompromiso DateTime
  fechaPagoReal   DateTime?
  estado          String   @default("PENDIENTE") // PENDIENTE | PARCIAL | LIQUIDADO | VENCIDO
  cuentaOrigenId  String?
  cuentaOrigen    CuentaBancaria? @relation(fields: [cuentaOrigenId], references: [id])
  movimientoId    String?  @unique
  movimiento      MovimientoFinanciero? @relation(fields: [movimientoId], references: [id])
  notas           String?
  montoOriginal   Float?   // monto al momento de la creación, antes de ajustes
  ajustesLog      String?  // JSON: [{fecha, de, a, motivo, usuario}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cuentas_pagar")
}

// ─── EVALUACIÓN ──────────────────────────────────────────────────────────────

model EvaluacionInterna {
  id                    String   @id @default(cuid())
  proyectoId            String   @unique
  proyecto              Proyecto @relation(fields: [proyectoId], references: [id])
  planeacionPrevia      Int?
  cumplimientoTecnico   Int?
  puntualidad           Int?
  resolucionOperativa   Int?
  desempenoPersonal     Int?
  comunicacionInterna   Int?
  comunicacionCliente   Int?
  usoEquipo             Int?
  rentabilidadReal      Int?
  resultadoGeneral      Int?
  promedioCalculado     Float?
  notas                 String?
  comentariosCriterios  String?  // JSON: {criterioKey: "texto"}
  reportePostEvento     String?  // JSON: [{area, problema, causa, solucion}]
  createdAt             DateTime @default(now())

  @@map("evaluaciones_internas")
}

// ─── EVALUACIÓN CLIENTE ──────────────────────────────────────────────────────

model EvaluacionCliente {
  id                        String    @id @default(cuid())
  proyectoId                String    @unique
  proyecto                  Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tokenAcceso               String    @unique @default(cuid())
  enviada                   Boolean   @default(false)
  respondida                Boolean   @default(false)
  // Criterios 1-10
  satisfaccionGeneral       Int?
  calidadServicio           Int?
  puntualidad               Int?
  atencionEquipo            Int?
  claridadComunicacion      Int?
  relacionCalidadPrecio     Int?
  // NPS 1-10
  probabilidadRecontratacion Int?
  // Texto libre
  loMejor                   String?
  loMejorable               String?
  comentarioAdicional       String?
  promedioCalculado         Float?
  createdAt                 DateTime  @default(now())
  respondidaEn              DateTime?

  @@map("evaluaciones_clientes")
}

// ─── VENTAS / COMISIONES ─────────────────────────────────────────────────────

model ConfigComisiones {
  id                   String   @id @default(cuid())
  // Metas ramp-up
  metaMes1             Float    @default(60000)
  metaMes2             Float    @default(80000)
  metaMes3             Float    @default(100000)
  metaMesNormal        Float    @default(150000)
  // Porcentajes comisión base
  pctClientePropio     Float    @default(10)   // 10% cliente propio
  pctPublicidad        Float    @default(5)    // 5% lead por publicidad
  pctAsignadoVendedor  Float    @default(5)    // 5% al vendedor que cierra (cliente asignado)
  pctAsignadoOrigen    Float    @default(5)    // 5% al vendedor original (cliente asignado)
  // Bono
  pctBono              Float    @default(3)    // 3% si alcanza el piso
  // Metas de prospección outbound
  metaProspectoDiaria  Int      @default(12)   // prospectos outbound mínimos por día
  updatedAt            DateTime @updatedAt

  @@map("config_comisiones")
}

model ComisionPago {
  id          String   @id @default(cuid())
  vendedorId  String
  vendedor    User     @relation(fields: [vendedorId], references: [id])
  mes         String   // "2026-04"
  montoTotal  Float
  notas       String?
  pagadoEn    DateTime @default(now())

  @@map("comision_pagos")
}

// ─── MANTENIMIENTO ───────────────────────────────────────────────────────────

model EquipoUnidad {
  id        String   @id @default(cuid())
  equipoId  String
  equipo    Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  codigo    String?  // Número de serie, tag, etiqueta, ej: "SN-12345" o "Unidad 1"
  estado    String   @default("ACTIVO") // ACTIVO | EN_MANTENIMIENTO | DADO_DE_BAJA
  notas     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  mantenimientos MantenimientoEquipo[]

  @@map("equipo_unidades")
}

model MantenimientoEquipo {
  id                   String        @id @default(cuid())
  equipoId             String
  equipo               Equipo        @relation(fields: [equipoId], references: [id])
  unidadId             String?
  unidad               EquipoUnidad? @relation(fields: [unidadId], references: [id])
  fecha                DateTime
  tipo                 String        // PREVENTIVO | CORRECTIVO | ESTETICO | FUNCIONAL
  accionRealizada      String
  estadoEquipo         String?
  comentarios          String?
  proximoMantenimiento DateTime?
  fotoEvidencia        String?       // base64 data URL
  createdAt            DateTime      @default(now())

  @@map("mantenimientos_equipos")
}

// ─── RECURSOS HUMANOS ────────────────────────────────────────────────────────

model PersonalInterno {
  id             String    @id @default(cuid())
  nombre         String
  puesto         String    // Ej: "Bodega", "Coordinación Logística"
  departamento   String    @default("GENERAL") // BODEGA | COORDINACION | PRODUCCION | ADMINISTRACION | VENTAS | GENERAL
  tipo           String    @default("EMPLEADO") // EMPLEADO | FREELANCE_RECURRENTE
  telefono       String?
  correo         String?
  salario        Float?    // Mensual (empleado) o tarifa base (freelance recurrente)
  periodoPago    String    @default("MENSUAL") // MENSUAL | QUINCENAL | SEMANAL | POR_EVENTO
  fechaIngreso   DateTime?
  activo         Boolean   @default(true)
  cuentaBancaria String?
  datosFiscales  String?
  notas          String?
  // Datos bancarios
  banco          String?
  clabe          String?   @map("clabe")
  numeroCuenta   String?   @map("numero_cuenta")
  numeroTarjeta  String?   @map("numero_tarjeta")
  // Datos personales
  ineUrl         String?   @map("ine_url")
  domicilio      String?
  // Contacto de emergencia
  emergenciaNombre String? @map("emergencia_nombre")
  emergenciaTel    String? @map("emergencia_tel")
  // Salud
  padecimientos  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  documentos    DocumentoPersonal[]
  pagos         PagoNomina[]
  asistencias   Asistencia[]
  incidencias   Incidencia[]
  evaluaciones  EvaluacionEmpleado[]

  @@map("personal_interno")
}

model DocumentoPersonal {
  id               String          @id @default(cuid())
  personalId       String
  personal         PersonalInterno @relation(fields: [personalId], references: [id], onDelete: Cascade)
  tipo             String          // CONTRATO | IDENTIFICACION | CURP | RFC | COMPROBANTE_DOMICILIO | OTRO
  nombre           String
  url              String
  fechaVencimiento DateTime?
  createdAt        DateTime        @default(now())

  @@map("documentos_personal")
}

model PagoNomina {
  id             String               @id @default(cuid())
  personalId     String
  personal       PersonalInterno      @relation(fields: [personalId], references: [id])
  periodo        String               // "2026-04"
  tipoPeriodo    String               @default("MENSUAL") // MENSUAL | QUINCENAL | SEMANAL | EVENTO
  monto          Float
  concepto       String?
  estado         String               @default("PENDIENTE") // PENDIENTE | PAGADO
  fechaPago      DateTime?
  metodoPago     String               @default("TRANSFERENCIA")
  cuentaOrigenId String?
  cuentaOrigen   CuentaBancaria?      @relation(fields: [cuentaOrigenId], references: [id])
  movimientoId   String?              @unique
  movimiento     MovimientoFinanciero? @relation(fields: [movimientoId], references: [id])
  notas          String?
  createdAt      DateTime             @default(now())

  @@map("pagos_nomina")
}

// ─── ASISTENCIA E INCIDENCIAS ────────────────────────────────────────────────

model Asistencia {
  id             String          @id @default(cuid())
  personalId     String
  personal       PersonalInterno @relation(fields: [personalId], references: [id], onDelete: Cascade)
  fecha          DateTime
  estado         String          // PRESENTE | FALTA | RETARDO | PERMISO | VACACIONES | INCAPACIDAD
  minutosRetardo Int?
  horaEntrada    String?
  horaSalida     String?
  notas          String?
  createdAt      DateTime        @default(now())

  @@unique([personalId, fecha])
  @@map("asistencias")
}

model TipoIncidencia {
  id          String  @id @default(cuid())
  nombre      String
  categoria   String  // ASISTENCIA | CONDUCTA | DESEMPEÑO | RECONOCIMIENTO
  calculoTipo String  @default("SIN_DESCUENTO") // FIJO | PORCENTAJE_DIA | PORCENTAJE_HORA | SIN_DESCUENTO
  valor       Float   @default(0)
  esDescuento Boolean @default(true)
  descripcion String?
  activo      Boolean @default(true)

  incidencias Incidencia[]

  @@map("tipos_incidencia")
}

model Incidencia {
  id             String          @id @default(cuid())
  personalId     String
  personal       PersonalInterno @relation(fields: [personalId], references: [id], onDelete: Cascade)
  tipoId         String
  tipo           TipoIncidencia  @relation(fields: [tipoId], references: [id])
  fecha          DateTime
  descripcion    String?
  montoCalculado Float?
  periodoNomina  String?         // "2026-04"
  aplicada       Boolean         @default(false)
  notificada     Boolean         @default(false)
  createdAt      DateTime        @default(now())

  @@map("incidencias")
}

model EvaluacionEmpleado {
  id           String          @id @default(cuid())
  personalId   String
  personal     PersonalInterno @relation(fields: [personalId], references: [id], onDelete: Cascade)
  periodo      String
  evaluador    String?
  fecha        DateTime        @default(now())

  puntualidad      Int @default(0)
  ordenLimpieza    Int @default(0)
  actitud          Int @default(0)
  comunicacion     Int @default(0)
  resolucionProb   Int @default(0)
  propuestasMejora Int @default(0)
  calidadTrabajo   Int @default(0)
  trabajoEquipo    Int @default(0)

  aspectosPositivos String?
  areasMejora       String?
  incidentesNota    String?
  observaciones     String?

  puntajeTotal Float?
  estado       String   @default("BORRADOR") // BORRADOR | COMPLETADA
  createdAt    DateTime @default(now())

  @@map("evaluaciones_empleado")
}

// ─── BODEGA ──────────────────────────────────────────────────────────────────

model ItemTemplateBodega {
  id          String  @id @default(cuid())
  descripcion String
  categoria   String  @default("GENERAL") // AUDIO | ILUMINACION | VIDEO | CABLES | HERRAMIENTAS | TRANSPORTES | GENERAL
  orden       Int     @default(0)
  activo      Boolean @default(true)

  @@map("items_template_bodega")
}

model ChecklistBodega {
  id          String    @id @default(cuid())
  semana      String    // "2026-W15" (ISO año + semana)
  fechaInicio DateTime
  estado      String    @default("EN_PROGRESO") // EN_PROGRESO | COMPLETADO | CON_ALERTAS
  notas       String?
  creadoPor   String?
  cerradoEn   DateTime?
  createdAt   DateTime  @default(now())

  items ChecklistBodegaItem[]

  @@unique([semana])
  @@map("checklist_bodega")
}

model ChecklistBodegaItem {
  id          String          @id @default(cuid())
  checklistId String
  checklist   ChecklistBodega @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  descripcion String
  categoria   String          @default("GENERAL")
  estado      String          @default("PENDIENTE") // PENDIENTE | OK | FALTA | DAÑADO | EN_REPARACION
  notas       String?
  equipoId    String?
  equipo      Equipo?         @relation(fields: [equipoId], references: [id])
  orden       Int             @default(0)

  @@map("checklist_bodega_items")
}

// ─── MARKETING ───────────────────────────────────────────────────────────────

model TipoContenido {
  id           String  @id @default(cuid())
  nombre       String
  formato      String  @default("POST") // POST | REEL | STORIE | TIK_TOK
  objetivo     String?
  diaSemana    String? // Día(s) separados por coma, ej: "LUNES,VIERNES"
  semanaDelMes Int?    // 1=primer, 2=segundo, 3=tercer, 4=cuarto (para publicaciones 1x/mes en día específico)
  recurrencia  String?
  cantMes      Int?
  descripcion  String?
  activo       Boolean @default(true)
  orden        Int     @default(0)
  enFacebook   Boolean @default(false)
  enInstagram  Boolean @default(false)
  enTiktok     Boolean @default(false)
  enYoutube    Boolean @default(false)
  enFeedIG     Boolean @default(false) // Aparece en previsualización Feed IG

  publicaciones Publicacion[]

  @@map("tipos_contenido")
}

model Publicacion {
  id             String         @id @default(cuid())
  fecha          DateTime
  tipoId         String?
  tipo           TipoContenido? @relation(fields: [tipoId], references: [id])
  formato        String?
  objetivo       String?
  descripcion    String?
  copy           String?
  enFacebook     Boolean        @default(false)
  enInstagram    Boolean        @default(false)
  enTiktok       Boolean        @default(false)
  enYoutube      Boolean        @default(false)
  materialLink   String?
  portadaUrl     String?        // URL de imagen de portada (para feed IG)
  colaboradores  String?
  estado         String         @default("PENDIENTE")
  comentarios    String?
  alcance        Int?
  impresiones    Int?
  interacciones  Int?
  seguidoresGanados Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("publicaciones")
}

// ─── CONFIGURACIÓN DE LA APP ─────────────────────────────────────────────────

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  @@map("app_config")
}

model ModuloAcceso {
  id        String   @id @default(cuid())
  moduloKey String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([moduloKey, userId])
  @@map("modulo_accesos")
}

// ─── PLANTILLAS DE EQUIPO (sugerencias por tipo evento/servicio/capacidad) ───

model PlantillaEquipo {
  id           String   @id @default(cuid())
  nombre       String
  tipoServicio String   @default("TODOS") // PRODUCCION_TECNICA | RENTA | TODOS
  tipoEvento   String   @default("TODOS") // MUSICAL | SOCIAL | EMPRESARIAL | OTRO | TODOS
  capacidadMin Int      @default(0)
  capacidadMax Int      @default(9999)
  descripcion  String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  items        PlantillaEquipoItem[]
  @@map("plantillas_equipo")
}

model PlantillaEquipoItem {
  id          String          @id @default(cuid())
  plantillaId String
  plantilla   PlantillaEquipo @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  equipoId    String?
  equipo      Equipo?         @relation(fields: [equipoId], references: [id])
  descripcion String
  cantidad    Int             @default(1)
  esOpcional  Boolean         @default(false)
  orden       Int             @default(0)
  notas       String?
  @@map("plantillas_equipo_items")
}

// ─── VEHÍCULOS Y MANTENIMIENTO ───────────────────────────────────────────────

model Vehiculo {
  id                   String    @id @default(cuid())
  nombre               String    // Nombre identificador Ej. "Sprinter Negra"
  marca                String?
  modelo               String?
  anio                 Int?
  placas               String?
  color                String?
  kilometraje          Int?      // Km actuales del odómetro
  proximoServicioKm    Int?      // Km en que toca el próximo servicio
  proximoServicioFecha DateTime? // Fecha del próximo servicio programado
  activo               Boolean   @default(true)
  notas                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  mantenimientos       MantenimientoVehiculo[]
  @@map("vehiculos")
}

model MantenimientoVehiculo {
  id             String    @id @default(cuid())
  vehiculoId     String
  vehiculo       Vehiculo  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  fecha          DateTime
  km             Int?      // Km al momento del registro
  tipoRegistro   String    // SERVICIO | REPARACION | REVISION | ACCIDENTE | OTRO
  servicio       String    // Descripción del trabajo realizado
  aceite         String?   // Tipo/número de aceite utilizado
  anticongelante String?   // Tipo/número de anticongelante
  estadoLlantas  String?   // Descripción del estado de llantas
  proximoKm      Int?      // Km para el próximo servicio
  proximaFecha   DateTime? // Fecha para el próximo servicio
  prioridad      String    @default("NORMAL") // BAJA | NORMAL | ALTA | URGENTE
  estatus        String    @default("COMPLETADO") // PENDIENTE | EN_PROCESO | COMPLETADO
  costo          Float?
  comentarios    String?
  createdAt      DateTime  @default(now())
  @@map("mantenimiento_vehiculos")
}

// ─── OPERACIONES ─────────────────────────────────────────────────────────────

model IniciativaExterna {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  area        String    @default("GENERAL") // VENTAS | ADMINISTRACION | PRODUCCION | MARKETING | RRHH | GENERAL
  estado      String    @default("ACTIVA")  // ACTIVA | COMPLETADA | ARCHIVADA
  color       String?
  creadoPorId String?
  creadoPor   User?     @relation("IniciativasCreadas", fields: [creadoPorId], references: [id])
  fechaInicio DateTime?
  fechaFin    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tareas Tarea[]

  @@map("iniciativas_externas")
}

model Tarea {
  id               String             @id @default(cuid())
  titulo           String
  descripcion      String?
  prioridad        String             @default("MEDIA")    // URGENTE | ALTA | MEDIA | BAJA
  area             String             @default("GENERAL")  // VENTAS | ADMINISTRACION | PRODUCCION | MARKETING | RRHH | GENERAL
  estado           String             @default("PENDIENTE") // PENDIENTE | EN_PROGRESO | COMPLETADA | CANCELADA
  asignadoAId      String?
  asignadoA        User?              @relation("TareasAsignadas",  fields: [asignadoAId], references: [id])
  creadoPorId      String?
  creadoPor        User?              @relation("TareasCreadoPor",  fields: [creadoPorId], references: [id])
  iniciativaId     String?
  iniciativa       IniciativaExterna? @relation(fields: [iniciativaId], references: [id], onDelete: SetNull)
  // ── Hierarchy ──────────────────────────────────────────────────────────────
  carpetaId        String?
  carpeta          TareaCarpeta?      @relation(fields: [carpetaId], references: [id], onDelete: SetNull)
  proyectoTareaId  String?
  proyectoTarea    TareaProyecto?     @relation(fields: [proyectoTareaId], references: [id], onDelete: SetNull)
  seccionId        String?
  seccion          TareaSeccion?      @relation(fields: [seccionId], references: [id], onDelete: SetNull)
  parentId         String?
  parent           Tarea?             @relation("TareaSubtareas", fields: [parentId], references: [id], onDelete: Cascade)
  subtareas        Tarea[]            @relation("TareaSubtareas")
  // ── Scheduling ──────────────────────────────────────────────────────────────
  fecha            DateTime?  // When to work on it (shows in Hoy)
  fechaVencimiento DateTime?
  fechaCompletada  DateTime?
  recurrencia      String?    // JSON: RecurrenciaConfig
  orden            Int        @default(0)
  // ── Content ──────────────────────────────────────────────────────────────
  notas            String?
  etiquetas        String?    // JSON string[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  comentarios      TareaComentario[]
  archivos         TareaArchivo[]

  @@map("tareas")
}

model TareaCarpeta {
  id          String          @id @default(cuid())
  nombre      String
  color       String?
  icono       String?
  orden       Int             @default(0)
  creadoPorId String?
  creadoPor   User?           @relation("CarpetasCreadas", fields: [creadoPorId], references: [id])
  proyectos   TareaProyecto[]
  tareas      Tarea[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("tarea_carpetas")
}

model TareaProyecto {
  id          String         @id @default(cuid())
  nombre      String
  descripcion String?
  color       String?
  icono       String?
  orden       Int            @default(0)
  archivado   Boolean        @default(false)
  carpetaId   String?
  carpeta     TareaCarpeta?  @relation(fields: [carpetaId], references: [id], onDelete: SetNull)
  creadoPorId String?
  creadoPor   User?          @relation("ProyectosTareaCreados", fields: [creadoPorId], references: [id])
  secciones   TareaSeccion[]
  tareas      Tarea[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("tarea_proyectos")
}

model TareaSeccion {
  id         String        @id @default(cuid())
  nombre     String
  orden      Int           @default(0)
  colapsada  Boolean       @default(false)
  proyectoId String
  proyecto   TareaProyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tareas     Tarea[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("tarea_secciones")
}

model TareaComentario {
  id        String   @id @default(cuid())
  contenido String
  tareaId   String
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  autorId   String?
  autor     User?    @relation("ComentariosTarea", fields: [autorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tarea_comentarios")
}

// ─── GASTOS OPERATIVOS ───────────────────────────────────────────────────────
// Efectivo que coordinación necesita antes del evento: comidas, transporte, hospedaje.
// Se jalan de las líneas de cotización y admin marca si ya se entregó el dinero.
model GastoOperativo {
  id          String   @id @default(cuid())
  proyectoId  String
  proyecto    Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  tipo        String   // COMIDA | TRANSPORTE | HOSPEDAJE | OTRO
  concepto    String
  monto       Float
  cantidad    Int      @default(1)
  // Estado de entrega del efectivo a coordinación
  entregado   Boolean  @default(false)
  fechaEntrega DateTime?
  notas       String?
  createdAt   DateTime @default(now())

  @@map("gastos_operativos")
}

model TareaArchivo {
  id          String   @id @default(cuid())
  nombre      String
  url         String
  tipo        String?  // MIME type or category
  tamano      Int?     // bytes
  tareaId     String
  tarea       Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  subidoPorId String?
  subidoPor   User?    @relation("ArchivosTarea", fields: [subidoPorId], references: [id])
  createdAt   DateTime @default(now())

  @@map("tarea_archivos")
}

// ─── TALENTO / ATS ───────────────────────────────────────────────────────────

model PuestoIdeal {
  id          String  @id @default(cuid())
  titulo      String
  area        String  // PRODUCCION | ADMINISTRACION | COMERCIAL | OPERACIONES | RRHH | TECNOLOGIA
  descripcion String?
  objetivoRol String? @map("objetivo_rol")

  // Perfil demográfico
  edadMin           Int?    @map("edad_min")
  edadMax           Int?    @map("edad_max")
  ciudades          String? // JSON array
  nivelEstudios     String? @map("nivel_estudios") // BACHILLERATO | LICENCIATURA | POSGRADO | INDIFERENTE
  carrerasSugeridas String? @map("carreras_sugeridas")

  // Competencias (JSON arrays de strings)
  habilidadesTecnicas String? @map("habilidades_tecnicas")
  habilidadesBlandas  String? @map("habilidades_blandas")
  conocimientos       String?
  aptitudes           String?
  valores             String?
  areasDesarrollo     String? @map("areas_desarrollo")

  // Criterios de evaluación JSON: [{criterio, peso, descripcion}]
  criteriosEvaluacion String? @map("criterios_evaluacion")

  // Condiciones
  salarioMin   Float?  @map("salario_min")
  salarioMax   Float?  @map("salario_max")
  tipoContrato String? @map("tipo_contrato") // NOMINA | HONORARIOS | FREELANCE
  modalidad    String? // PRESENCIAL | REMOTO | HIBRIDO
  horario      String?
  prestaciones String? // JSON array

  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  postulaciones Postulacion[]

  @@map("puestos_ideales")
}

model Candidato {
  id       String  @id @default(cuid())
  nombre   String
  correo   String?
  telefono String?
  ciudad   String?
  edad     Int?
  nivelEstudios String? @map("nivel_estudios")
  carrera  String?

  // Discovery form
  experienciaEventos      String?  @map("experiencia_eventos")
  aniosExperienciaEventos Int?     @map("anios_experiencia_eventos")
  eventoDestacado         String?  @map("evento_destacado")
  situacionResuelta       String?  @map("situacion_resuelta")
  comoResolveria          String?  @map("como_resolveria")
  motivacion              String?
  visionLargoPlazo        String?  @map("vision_largo_plazo")
  disposicionHorario      Boolean? @map("disposicion_horario")
  disposicionFines        Boolean? @map("disposicion_fines")
  salarioEsperado         Float?   @map("salario_esperado")
  habilidades             String?
  experienciaPrevia       String?  @map("experiencia_previa")
  linkedin                String?
  portfolio               String?
  notas                   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  postulaciones Postulacion[]

  @@map("candidatos")
}

model Postulacion {
  id          String  @id @default(cuid())
  candidatoId String  @map("candidato_id")
  candidato   Candidato   @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  puestoId    String? @map("puesto_id")
  puesto      PuestoIdeal? @relation(fields: [puestoId], references: [id])

  // Puesto manual si no hay PuestoIdeal vinculado
  puestoManual String? @map("puesto_manual")
  areaManual   String? @map("area_manual")

  // Pipeline
  etapa String @default("NUEVO") // NUEVO | EVALUACION | PROPUESTA_ENVIADA | APROBADO | CONTRATADO | RECHAZADO

  // Propuesta de trabajo
  salarioPropuesto     Float?    @map("salario_propuesto")
  fechaIngresoEstimada DateTime? @map("fecha_ingreso_estimada")
  beneficios           String?   // JSON array
  observaciones        String?
  propuestaToken       String?   @unique @map("propuesta_token")
  propuestaAceptada    Boolean?  @map("propuesta_aceptada")
  propuestaFechaEnvio  DateTime? @map("propuesta_fecha_envio")

  // Contrato
  contratoGenerado Boolean  @default(false) @map("contrato_generado")
  contratoFecha    DateTime? @map("contrato_fecha")

  // Link al PersonalInterno creado al contratar
  personalInternoId String? @map("personal_interno_id")

  // Evaluación vs perfil
  notasEvaluacion String? @map("notas_evaluacion")
  puntajeTotal    Float?  @map("puntaje_total")

  // Onboarding checklist (JSON: [{id,label,done,fecha}])
  onboardingData  String?

  onboardingPlan  OnboardingPlan?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("postulaciones")
}

// ─── ONBOARDING ───────────────────────────────────────────────────────────────

model OnboardingPlan {
  id             String   @id @default(cuid())
  nombre         String
  puesto         String
  area           String?
  fechaIngreso   DateTime? @map("fecha_ingreso")
  estado         String   @default("EN_CURSO") // EN_CURSO | COMPLETADO | PAUSADO | CANCELADO
  notas          String?
  postulacionId  String?  @unique @map("postulacion_id")
  postulacion    Postulacion? @relation(fields: [postulacionId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")
  modulos        OnboardingModulo[]

  @@map("onboarding_planes")
}

model OnboardingModulo {
  id           String   @id @default(cuid())
  planId       String   @map("plan_id")
  plan         OnboardingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  nombre       String
  descripcion  String?
  tipo         String   @default("ALINEACION") // ALINEACION | TECNICO | ADMINISTRATIVO | CULTURAL | PRACTICO
  orden        Int      @default(0)
  duracionDias Int?     @map("duracion_dias")
  completado   Boolean  @default(false)
  tareas       OnboardingTarea[]

  @@map("onboarding_modulos")
}

model OnboardingTarea {
  id           String    @id @default(cuid())
  moduloId     String    @map("modulo_id")
  modulo       OnboardingModulo @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  titulo       String
  descripcion  String?
  tipo         String    @default("LECTURA") // LECTURA | VIDEO | PRACTICA | EVALUACION | REUNION | SHADOWING
  orden        Int       @default(0)
  completada   Boolean   @default(false)
  completadaEn DateTime? @map("completada_en")
  recurso      String?
  notas        String?

  @@map("onboarding_tareas")
}

// ─── CAMPAÑAS ─────────────────────────────────────────────────────────────────

model TipoCampana {
  id                  String   @id @default(cuid())
  nombre              String
  objetivo            String   @default("INFORMATIVO")  // INFORMATIVO | VENTA | ENTRETENIMIENTO | POSICIONAMIENTO
  objetivoMeta        String   @default("RECONOCIMIENTO") // RECONOCIMIENTO | TRAFICO | INTERACCION | LEADS | VENTAS
  formato             String   @default("VIDEO")         // IMAGEN | VIDEO | CARRUSEL | REEL | HISTORIA | COLECCION
  recurrencia         String   @default("MENSUAL")       // MENSUAL | QUINCENAL | SEMANAL
  canal               String   @default("META")
  duracionDias        Int      @default(14)
  presupuestoEstimado Float?
  publicoEdadMin      Int      @default(25)
  publicoEdadMax      Int      @default(55)
  publicoGenero       String   @default("TODOS")         // TODOS | HOMBRES | MUJERES
  ubicaciones         String   @default("FEED_IG,REELS_IG,STORIES_IG")
  cta                 String   @default("MAS_INFORMACION")
  copyReferencia      String?
  pixelEvento         String?
  descripcion         String?
  color               String   @default("#B3985B")
  activo              Boolean  @default(true)
  orden               Int      @default(0)
  createdAt           DateTime @default(now())

  ejecuciones         EjecucionCampana[]

  @@map("tipos_campana")
}

model EjecucionCampana {
  id             String       @id @default(cuid())
  tipoId         String?
  tipo           TipoCampana? @relation(fields: [tipoId], references: [id])
  nombre         String
  objetivo       String?
  canal          String?
  color          String?
  fechaInicio    DateTime
  fechaFin       DateTime
  estado         String       @default("PLANIFICADA") // PLANIFICADA | EN_EJECUCION | COMPLETADA | CANCELADA
  presupuesto    Float?
  notas          String?
  mes            String       // YYYY-MM
  idMetaAds      String?
  alcance        Int?
  impresiones    Int?
  clics          Int?
  ctr            Float?
  cantResultados Int?
  costoResultado Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("ejecuciones_campana")
}

// ─── META ADS ─────────────────────────────────────────────────────────────────

model MetaCampana {
  id             String   @id @default(cuid())
  nombre         String
  objetivo       String   @default("LEADS")   // LEADS | AWARENESS | CONVERSIONES | TRAFICO
  estado         String   @default("BORRADOR") // BORRADOR | ACTIVA | PAUSADA | FINALIZADA
  presupuesto    Float    @default(0)
  fechaInicio    DateTime?
  fechaFin       DateTime?
  audiencia      String?  // JSON: segmentación de audiencia
  ubicaciones    String?  // JSON: plataformas (Facebook, Instagram, Audience Network)
  notas          String?
  creadoPorId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  anuncios       MetaAnuncio[]
  resultados     MetaResultado[]

  @@map("meta_campanas")
}

model MetaAnuncio {
  id          String   @id @default(cuid())
  campanaId   String
  campana     MetaCampana @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  nombre      String
  formato     String   @default("IMAGEN") // IMAGEN | VIDEO | CARRUSEL | HISTORIA
  titular     String?
  descripcion String?
  cta         String?  // Texto del call-to-action
  urlDestino  String?
  estado      String   @default("ACTIVO") // ACTIVO | PAUSADO | RECHAZADO
  notas       String?
  createdAt   DateTime @default(now())

  @@map("meta_anuncios")
}

model MetaResultado {
  id             String   @id @default(cuid())
  campanaId      String
  campana        MetaCampana @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  fecha          DateTime
  impresiones    Int      @default(0)
  alcance        Int      @default(0)
  clics          Int      @default(0)
  leads          Int      @default(0)
  gastado        Float    @default(0)
  cpm            Float?   // Costo por mil impresiones
  cpc            Float?   // Costo por clic
  cpl            Float?   // Costo por lead
  frecuencia     Float?
  notas          String?
  createdAt      DateTime @default(now())

  @@map("meta_resultados")
}

// ─── LEVANTAMIENTO DE CONTENIDO ──────────────────────────────────────────────

model LevantamientoContenido {
  id                          String    @id @default(cuid())
  tratoId                     String    @unique
  trato                       Trato     @relation(fields: [tratoId], references: [id], onDelete: Cascade)

  nombreEvento                String?
  tipoEvento                  String?
  fecha                       DateTime?
  horarioEvento               String?
  horarioCobertura            String?
  lugar                       String?
  nombreCliente               String?
  redesSocialesCliente        String?
  tieneProveedoresAdicionales String?   // SI | NO | SIN_INFO
  proveedoresDetalle          String?
  objetivosContenido          String?   // JSON array de strings
  detalleObjetivo             String?
  planCobertura               String?   // BASICO | ESTANDAR | PLUS | INTEGRAL | OTRO
  planCoberturaOtro           String?
  temasSugeridos              String?
  colaboradoresCamara         Boolean?
  colaboradoresNombres        String?
  notasAdicionales            String?

  activos   ActivoEvento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("levantamientos_contenido")
}

// ─── VENUES ──────────────────────────────────────────────────────────────────

model Venue {
  id                  String   @id @default(cuid())
  nombre              String
  direccion           String?
  ciudad              String?
  contacto            String?
  telefonoContacto    String?
  emailContacto       String?
  capacidadPersonas   Int?
  // Dimensiones
  largoM              Float?
  anchoM              Float?
  alturaMaximaM       Float?
  // Acceso
  accesoVehicular     String?
  puntoDescarga       String?
  // Electricidad
  voltajeDisponible   String?
  amperajeTotal       Float?
  fases               String?
  ubicacionTablero    String?
  // Restricciones
  restriccionDecibeles  String?
  restriccionHorario    String?
  restriccionInstalacion String?
  // Información adicional
  tiposEvento         String?  // JSON: ["MUSICAL","SOCIAL","EMPRESARIAL"]
  calificacion        Float?   // 1-5
  notas               String?
  fotoPortada         String?  // base64
  activo              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("venues")
}

// ─── PLANTILLAS DE COTIZACIÓN ─────────────────────────────────────────────────

model PlantillaCotizacion {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  tipoEvento    String?
  tipoServicio  String?
  activo        Boolean  @default(true)
  creadaPorId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Campos de cotización que se copian
  horasOperacion   Float?
  tipoJornada      String?
  diasEquipo       Int     @default(1)
  diasOperacion    Int     @default(1)
  diasTransporte   Int     @default(1)
  diasHospedaje    Int     @default(1)
  diasComidas      Int     @default(1)
  observaciones    String?
  terminosComerciales String?
  vigenciaDias     Int     @default(30)
  aplicaIva        Boolean @default(false)

  lineas PlantillaCotizacionLinea[]

  @@map("plantillas_cotizacion")
}

model PlantillaCotizacionLinea {
  id          String               @id @default(cuid())
  plantillaId String
  plantilla   PlantillaCotizacion  @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  tipo         String
  equipoId     String?
  equipo       Equipo?  @relation(fields: [equipoId], references: [id])
  rolTecnicoId String?
  descripcion    String
  marca          String?
  modelo         String?
  nivel          String?
  jornada        String?
  esExterno      Boolean @default(false)
  cantidad       Float   @default(1)
  dias           Int     @default(1)
  precioUnitario Float   @default(0)
  costoUnitario  Float   @default(0)
  subtotal       Float   @default(0)
  esIncluido     Boolean @default(false)
  notas          String?
  orden          Int     @default(0)

  @@map("plantillas_cotizacion_lineas")
}

// ─── CIERRE FINANCIERO DE PROYECTO ───────────────────────────────────────────

model CierreFinanciero {
  id         String   @id @default(cuid())
  proyectoId String   @unique
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // Estimado (de cotización)
  granTotalEstimado       Float @default(0)
  costoEstimado           Float @default(0)
  utilidadEstimada        Float @default(0)

  // Real (calculado al cierre)
  totalCobrado            Float @default(0)
  totalGastado            Float @default(0)
  utilidadReal            Float @default(0)
  margenReal              Float @default(0)

  // Detalle por categoría (JSON)
  desgloseCostos          String? // JSON: [{categoria, monto}]
  notas                   String?

  cerradoEn               DateTime @default(now())
  cerradoPorId            String?

  @@map("cierres_financieros")
}

// ─── ESTRUCTURA DE CAPITAL (HERVAM) ──────────────────────────────────────────

model HervamActivo {
  id               String   @id @default(cuid())
  nombre           String
  descripcion      String?
  categoria        String   @default("EQUIPO") // EQUIPO | VEHICULO | INMUEBLE | INTANGIBLE | OTRO
  valorAdquisicion Float    @default(0)
  valorActual      Float    @default(0)
  fechaAdquisicion DateTime?
  activo           Boolean  @default(true)
  notas            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@map("hervam_activos")
}

model HervamConfig {
  id                   String   @id @default(cuid())
  socioId              String?
  socio                Socio?   @relation(fields: [socioId], references: [id])
  // Valuación
  valorTotalActivos    Float    @default(5000000)
  tasaAnualRendimiento Float    @default(15)
  usarSumaActivos      Boolean  @default(false) // true = calcula desde activos; false = usa valorTotalActivos
  // Modo
  modoActivo           String   @default("HIBRIDO") // FIJO | VARIABLE | HIBRIDO
  porcentajeVariable   Float    @default(25)
  pisoMinimoFijo       Float    @default(50)  // % del monto fijo como garantía mínima
  // Crédito
  creditoSaldoInicial  Float    @default(800000)
  creditoSaldoActual   Float    @default(800000)
  creditoCuotaMensual  Float    @default(0)
  creditoPlazoMeses    Int      @default(48)
  creditoFechaInicio   DateTime?
  // Meta
  notas                String?
  actualizadoEn        DateTime @updatedAt
  @@map("hervam_config")
}

model HervamPago {
  id            String    @id @default(cuid())
  mes           Int
  anio          Int
  montoFijo     Float
  utilidadMes   Float?
  montoVariable Float?
  montoAcordado Float
  montoPagado   Float     @default(0)
  estado        String    @default("PENDIENTE") // PENDIENTE | PARCIAL | PAGADO | DIFERIDO
  modoPago      String?   // FIJO | VARIABLE
  notas         String?
  pagadoEn      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@unique([mes, anio])
  @@map("hervam_pagos")
}

// ─── SOCIOS DE ACTIVOS ────────────────────────────────────────────────────────

model Socio {
  id             String    @id @default(cuid())
  nombre         String
  tipo           String    @default("FISICA") // FISICA | MORAL
  rfc            String?
  curp           String?
  telefono       String?
  email          String?
  domicilio      String?
  colonia        String?
  ciudad         String?
  estado         String?
  cp             String?
  status         String    @default("EN_REVISION") // EN_REVISION | ACTIVO | SUSPENDIDO | INACTIVO
  notas          String?
  contratoInicio DateTime?
  contratoFin    DateTime?
  pctSocio       Float     @default(70)
  pctMainstage   Float     @default(30)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  activos      SocioActivo[]
  reportes     SocioReporte[]
  checklist    SocioRequisitoItem[]
  cuentasPagar CuentaPagar[]
  hervamConfig HervamConfig[]

  @@map("socios")
}

model SocioRequisitoItem {
  id         String   @id @default(cuid())
  socioId    String
  socio      Socio    @relation(fields: [socioId], references: [id], onDelete: Cascade)
  requisito  String
  completado Boolean  @default(false)
  notas      String?
  orden      Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("socios_requisitos")
}

model SocioActivo {
  id                   String    @id @default(cuid())
  socioId              String
  socio                Socio     @relation(fields: [socioId], references: [id], onDelete: Cascade)
  codigoInventario     String    @unique
  nombre               String
  marca                String?
  modelo               String?
  serial               String?
  categoria            String    @default("AUDIO") // AUDIO | ILUMINACION | VIDEO | ESTRUCTURAS | ACCESORIOS | OTRO
  condicion            String    @default("BUENO")  // NUEVO | EXCELENTE | BUENO | REGULAR | REQUIERE_MANTENIMIENTO
  valorDeclarado       Float     @default(0)
  precioDia            Float     @default(0)
  pctSocioOverride     Float?
  pctMainstageOverride Float?
  fotosUrls            String    @default("[]")
  activo               Boolean   @default(true)
  notas                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  rentas         SocioRenta[]
  mantenimientos SocioMantenimiento[]

  @@map("socios_activos")
}

model SocioMantenimiento {
  id             String      @id @default(cuid())
  activoId       String
  activo         SocioActivo @relation(fields: [activoId], references: [id], onDelete: Cascade)
  tipo           String      // PREVENTIVO | CORRECTIVO | INSPECCION
  descripcion    String
  fechaEjecucion DateTime?
  costoTotal     Float       @default(0)
  costoSocio     Float       @default(0)
  costoMainstage Float       @default(0)
  realizadoPor   String?
  notas          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("socios_mantenimientos")
}

model SocioRenta {
  id             String      @id @default(cuid())
  activoId       String
  activo         SocioActivo @relation(fields: [activoId], references: [id], onDelete: Cascade)
  descripcion    String
  proyectoId     String?
  mes            Int
  anio           Int
  fechaInicio    DateTime?
  fechaFin       DateTime?
  dias           Int         @default(1)
  precioDia      Float
  subtotal       Float
  pctSocio       Float
  pctMainstage   Float
  montoSocio     Float
  montoMainstage Float
  notas          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("socios_rentas")
}

model SocioReporte {
  id             String    @id @default(cuid())
  socioId        String
  socio          Socio     @relation(fields: [socioId], references: [id], onDelete: Cascade)
  mes            Int
  anio           Int
  totalEventos   Int       @default(0)
  totalDias      Int       @default(0)
  totalFacturado Float     @default(0)
  totalSocio     Float     @default(0)
  totalMainstage Float     @default(0)
  estado         String    @default("BORRADOR") // BORRADOR | ENVIADO | PAGADO
  pagadoEn       DateTime?
  notas          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([socioId, mes, anio])
  @@map("socios_reportes")
}

// ─── REPORTES SEMANALES ───────────────────────────────────────────────────────

model ReporteSemanal {
  id          String   @id @default(cuid())
  semana      DateTime // Lunes de la semana (date only, UTC midnight)
  fechaInicio DateTime
  fechaFin    DateTime
  datos       String   // JSON con todas las métricas
  score       Int      @default(0) // 0-100
  notas       String?  // Anotaciones del CEO
  generadoEn  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([semana])
  @@map("reportes_semanales")
}

// ─── MÉTRICAS ORGÁNICAS ───────────────────────────────────────────────────────

model MetricaOrganica {
  id            String   @id @default(cuid())
  mes           String   // YYYY-MM
  plataforma    String   // INSTAGRAM | FACEBOOK | TIKTOK | YOUTUBE
  seguidores    Int?
  alcance       Int?
  impresiones   Int?
  interacciones Int?
  publicaciones Int?
  notas         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([mes, plataforma])
  @@map("metricas_organicas")
}

// ─── ACTIVOS POR EVENTO ───────────────────────────────────────────────────────

model ActivoEvento {
  id               String                 @id @default(cuid())
  levantamientoId  String
  levantamiento    LevantamientoContenido @relation(fields: [levantamientoId], references: [id], onDelete: Cascade)
  tipo             String                 // FOTO | VIDEO | LOGO | COPY | OTRO
  nombre           String
  url              String
  descripcion      String?
  estado           String                 @default("ENTREGADO") // PENDIENTE | EN_EDICION | ENTREGADO | APROBADO
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@map("activos_evento")
}

// ─── NOTIFICACIONES ───────────────────────────────────────────────────────────

model Notificacion {
  id          String   @id @default(cuid())
  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo        String   // LEVANTAMIENTO | PUBLICACION | CAMPANA | SISTEMA
  titulo      String
  mensaje     String
  leida       Boolean  @default(false)
  url         String?
  metadata    String?  // JSON extra data
  createdAt   DateTime @default(now())

  @@index([usuarioId, leida])
  @@map("notificaciones")
}
